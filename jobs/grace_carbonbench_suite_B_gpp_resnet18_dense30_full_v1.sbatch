#!/bin/bash
# B: Full-patch GPP baseline, ResNet18 patch + tabular/metadata + dense temporal branch.
#SBATCH --job-name=cb_B_r18_t30
#SBATCH --partition=gpu
#SBATCH --gres=gpu:a100:1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=05:00:00
#SBATCH --output=/scratch/user/%u/afmnet/logs/%x-%j.out
#SBATCH --error=/scratch/user/%u/afmnet/logs/%x-%j.err

set -euo pipefail

module purge
module load GCC/13.2.0 OpenMPI/4.1.6 PyTorch/2.7.0 CUDA/12.6.0
source /scratch/user/$USER/afmnet/envs/afmnet-py311/bin/activate

cd /scratch/user/$USER/afmnet/classification

export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK}"
export NUMEXPR_MAX_THREADS="${SLURM_CPUS_PER_TASK}"
export MPLBACKEND=Agg
export PYTHONUNBUFFERED=1

export CARBONBENCH_DATA_ROOT="${CARBONBENCH_DATA_ROOT:-/scratch/user/$USER/afmnet/flux_data/carbonbench}"
export CARBONBENCH_SPLIT_FILE="${CARBONBENCH_SPLIT_FILE:-$CARBONBENCH_DATA_ROOT/split_enf_C_to_D_min1095.csv}"
export CARBONBENCH_PATCH_MANIFEST_FILE="${CARBONBENCH_PATCH_MANIFEST_FILE:-$CARBONBENCH_DATA_ROOT/patch_manifest_enf_C_to_D_hls_full_v1_downloaded.csv}"
export CARBONBENCH_RESTRICT_TO_PATCH_MANIFEST="${CARBONBENCH_RESTRICT_TO_PATCH_MANIFEST:-1}"
export CARBONBENCH_ERA5_FILE="${CARBONBENCH_ERA5_FILE:-$CARBONBENCH_DATA_ROOT/ERA5_enf_CD.parquet}"
export CARBONBENCH_USE_IMAGE_BRANCH="${CARBONBENCH_USE_IMAGE_BRANCH:-1}"
export CARBONBENCH_IMAGE_ENCODER_TYPE="${CARBONBENCH_IMAGE_ENCODER_TYPE:-resnet18}"
export CARBONBENCH_IMAGE_RESNET_VARIANT="${CARBONBENCH_IMAGE_RESNET_VARIANT:-resnet18}"
export CARBONBENCH_IMAGE_RESNET_PRETRAINED="${CARBONBENCH_IMAGE_RESNET_PRETRAINED:-0}"
export CARBONBENCH_USE_SEQUENCE_BRANCH="${CARBONBENCH_USE_SEQUENCE_BRANCH:-1}"
export CARBONBENCH_SEQUENCE_LENGTH="${CARBONBENCH_SEQUENCE_LENGTH:-30}"
export CARBONBENCH_SEQUENCE_INCLUDE_CURRENT="${CARBONBENCH_SEQUENCE_INCLUDE_CURRENT:-0}"
export CARBONBENCH_SEQUENCE_ENCODER_TYPE="${CARBONBENCH_SEQUENCE_ENCODER_TYPE:-gru}"
export CARBONBENCH_SEQUENCE_EMBEDDING_DIM="${CARBONBENCH_SEQUENCE_EMBEDDING_DIM:-128}"
export CARBONBENCH_MAMBA_D_MODEL="${CARBONBENCH_MAMBA_D_MODEL:-128}"
export CARBONBENCH_MAMBA_LAYERS="${CARBONBENCH_MAMBA_LAYERS:-2}"
export CARBONBENCH_TARGET_COLUMN="${CARBONBENCH_TARGET_COLUMN:-GPP_NT_VUT_USTAR50}"
export CARBONBENCH_EXPERIMENT_NAME="${CARBONBENCH_EXPERIMENT_NAME:-suite_B_gpp_resnet18_dense30_full_v1}"

python -u train.py \
  --dataset carbonbench_flux \
  --batch_size "${BATCH_SIZE:-16}" \
  --epochs "${EPOCHS:-30}" \
  --cam_samples 0
